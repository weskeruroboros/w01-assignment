<%- include("partials/header") %>

<main class="container" style="max-width: 800px; margin: 40px auto; padding: 0 15px;">
  <div style="background: #ffffff; border: 1px solid #e5e7eb; padding: 24px; border-radius: 8px;">
    <h2 style="margin-top: 0; color: #111827; font-size: 1.75rem;"><%= organization.name %></h2>

    <img src="<%= organization.image_url || '/images/home.jpg' %>" 
         alt="<%= organization.name %>" 
         onerror="this.src='/images/home.jpg';"
         style="max-width: 100%; max-height: 250px; border-radius: 6px; margin-bottom: 20px; object-fit: cover;">

    <div style="margin-bottom: 20px; color: #374151;">
      <p style="margin: 4px 0;"><strong>Email:</strong> <%= organization.email || 'N/A' %></p>
      <p style="margin: 4px 0;"><strong>Description:</strong> <%= organization.description || 'No description provided.' %></p>
    </div>

    <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 24px 0;">

    <h3 style="color: #111827; font-size: 1.25rem; margin-bottom: 12px;">Projects by this Organization</h3>
    <% if (projects && projects.length > 0) { %>
      <div style="display: grid; gap: 12px;">
        <% projects.forEach(p => { %>
          <div style="background: #f9fafb; padding: 12px 16px; border-radius: 6px; border: 1px solid #f3f4f6;">
            <strong style="color: #111827;"><%= p.title %></strong> 
            <% if (p.location) { %><span style="color: #6b7280; font-size: 0.85rem;"> — <%= p.location %></span><% } %>
            <% if (p.description) { %><p style="margin: 4px 0 0 0; color: #4b5563; font-size: 0.9rem;"><%= p.description %></p><% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color: #6b7280; font-size: 0.9rem;">No projects found for this organization.</p>
    <% } %>

    <!-- Action Buttons (Edit & Delete properly placed on details page) -->
    <div style="margin-top: 24px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #e5e7eb; padding-top: 20px; flex-wrap: wrap; gap: 1rem;">
      <div style="display: flex; gap: 12px; align-items: center;">
        <a href="/organizations/<%= organization.organization_id %>/edit" style="display: inline-flex; align-items: center; justify-content: center; height: 38px; padding: 0 16px; background: #ffffff; color: #2563eb; border: 1px solid #2563eb; border-radius: 6px; font-weight: 500; font-size: 0.9rem; text-decoration: none; box-sizing: border-box; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='#2563eb'; this.style.color='#ffffff'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#2563eb'; this.style.transform='translateY(0)';">Edit</a>
        
        <form action="/organizations/<%= organization.organization_id %>/delete" method="POST" style="margin: 0; display: inline-block; background: none; border: none; padding: 0;">
          <button type="submit" onclick="return confirm('Are you sure you want to delete this organization?');" style="display: inline-flex; align-items: center; justify-content: center; height: 38px; padding: 0 16px; background: #ffffff; color: #dc2626; border: 1px solid #dc2626; border-radius: 6px; font-weight: 500; font-size: 0.9rem; cursor: pointer; box-sizing: border-box; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='#dc2626'; this.style.color='#ffffff'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#dc2626'; this.style.transform='translateY(0)';">Delete</button>
        </form>
      </div>
      
      <a href="/organizations" style="color: #4b5563; text-decoration: none; font-size: 0.9rem;">Back to Organizations</a>
    </div>
  </div>
</main>

<%- include("partials/footer") %>