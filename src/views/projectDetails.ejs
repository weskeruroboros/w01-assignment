<%- include("partials/header") %>

<article class="project-details">
  <h2><%= project.title %></h2>
  <p><strong>Organization:</strong> <%= project.organization_name %></p>
  <p><strong>Location:</strong> <%= project.location %></p>
  <p><strong>Date:</strong> <%= project.project_date %></p>
  <p><strong>Description:</strong> <%= project.description %></p>

  <h3 style="margin-top: 20px; font-size: 18px; color: #1e293b;">Assigned Categories</h3>
  
  <% if (categories && categories.length > 0) { %>
    <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px;">
      <% categories.forEach(cat => { %>
        <span style="
          background-color: #f8fafc;
          color: #1e293b;
          border: 1px solid #e2e8f0;
          padding: 8px 16px;
          border-radius: 6px;
          font-size: 14px;
          font-weight: 500;
          box-shadow: 0 1px 2px rgba(0,0,0,0.05);
          display: inline-block;
        ">
          <%= cat.name %>
        </span>
      <% }) %>
    </div>
  <% } else { %>
    <p style="color: #64748b; font-style: italic;">No categories assigned yet.</p>
  <% } %>

  <!-- Action Buttons with Borders and Separation -->
  <div style="margin-top: 24px; display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
    <a href="/project/<%= project.project_id %>/edit" style="display: inline-flex; align-items: center; justify-content: center; height: 38px; padding: 0 16px; background: #ffffff; color: #2563eb; border: 1px solid #2563eb; border-radius: 6px; font-weight: 500; font-size: 0.9rem; text-decoration: none; box-sizing: border-box; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='#2563eb'; this.style.color='#ffffff'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#2563eb'; this.style.transform='translateY(0)';">
      Edit Project
    </a>
    
    <a href="/project/<%= project.project_id %>/assign-categories" style="display: inline-flex; align-items: center; justify-content: center; height: 38px; padding: 0 16px; background: #ffffff; color: #2563eb; border: 1px solid #2563eb; border-radius: 6px; font-weight: 500; font-size: 0.9rem; text-decoration: none; box-sizing: border-box; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='#2563eb'; this.style.color='#ffffff'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#2563eb'; this.style.transform='translateY(0)';">
      Assign / Update Categories
    </a>

    <form action="/project/<%= project.project_id %>/delete" method="POST" style="margin: 0; display: inline-block; background: none; border: none; padding: 0; box-shadow: none;">
      <button type="submit" onclick="return confirm('Are you sure you want to delete this project?');" style="display: inline-flex; align-items: center; justify-content: center; height: 38px; padding: 0 16px; background: #ffffff; color: #dc2626; border: 1px solid #dc2626; border-radius: 6px; font-weight: 500; font-size: 0.9rem; cursor: pointer; box-sizing: border-box; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='#dc2626'; this.style.color='#ffffff'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#dc2626'; this.style.transform='translateY(0)';">
        Delete Project
      </button>
    </form>
  </div>
  
  <p style="margin-top: 20px;"><a href="/projects">← Back to All Projects</a></p>
</article>

<%- include("partials/footer") %>