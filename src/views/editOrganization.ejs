<%- include("partials/header") %>

<h2>Edit Organization: <%= organization.name %></h2>

<form action="/organization/<%= organization.organization_id %>/edit" method="POST" class="form-container">
  <div class="form-group" style="margin-bottom: 12px;">
    <label for="name">Organization Name:</label>
    <input type="text" id="name" name="name" value="<%= organization.name %>" required style="width: 100%; padding: 8px;">
  </div>

  <div class="form-group" style="margin-bottom: 12px;">
    <label for="email">Email Address:</label>
    <input type="email" id="email" name="email" value="<%= organization.email %>" required style="width: 100%; padding: 8px;">
  </div>

  <div class="form-group" style="margin-bottom: 12px;">
    <label for="image_url">Image URL:</label>
    <input type="text" id="image_url" name="image_url" value="<%= organization.image_url %>" style="width: 100%; padding: 8px;">
  </div>

  <button type="submit" class="btn btn-primary">Update Organization</button>
  <a href="/organization/<%= organization.organization_id %>" class="btn btn-secondary">Cancel</a>
</form>

<%- include("partials/footer") %>