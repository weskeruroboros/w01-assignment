<%- include("partials/header") %>

<article class="project-details">
  <h2>Category: <%= category.name %></h2>
  <% if (category.description) { %>
    <p><strong>Description:</strong> <%= category.description %></p>
  <% } %>

  <h3 style="margin-top: 20px; font-size: 18px; color: #1e293b;">Associated Projects</h3>
  <% if (projects && projects.length > 0) { %>
    <ul style="margin-top: 10px; padding-left: 20px;">
      <% projects.forEach(p => { %>
        <li style="margin-bottom: 8px;">
          <a href="/project/<%= p.project_id %>"><strong><%= p.title %></strong></a> - <%= p.project_date %>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p style="color: #64748b; font-style: italic; margin-top: 10px;">No projects are currently assigned to this category.</p>
  <% } %>

  <!-- Action Buttons (Edit & Delete placed correctly on the details page) -->
  <div style="margin-top: 24px; display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
    <a href="/categories/<%= category.category_id %>/edit" style="display: inline-flex; align-items: center; justify-content: center; height: 38px; padding: 0 16px; background: #ffffff; color: #2563eb; border: 1px solid #2563eb; border-radius: 6px; font-weight: 500; font-size: 0.9rem; text-decoration: none; box-sizing: border-box; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='#2563eb'; this.style.color='#ffffff'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#2563eb'; this.style.transform='translateY(0)';">
      Edit Category
    </a>
    
    <form action="/categories/<%= category.category_id %>/delete" method="POST" style="margin: 0; display: inline-block; background: none; border: none; padding: 0;">
      <button type="submit" onclick="return confirm('Are you sure you want to delete this category?');" style="display: inline-flex; align-items: center; justify-content: center; height: 38px; padding: 0 16px; background: #ffffff; color: #dc2626; border: 1px solid #dc2626; border-radius: 6px; font-weight: 500; font-size: 0.9rem; cursor: pointer; box-sizing: border-box; transition: all 0.2s ease;" onmouseover="this.style.backgroundColor='#dc2626'; this.style.color='#ffffff'; this.style.transform='translateY(-2px)';" onmouseout="this.style.backgroundColor='#ffffff'; this.style.color='#dc2626'; this.style.transform='translateY(0)';">
        Delete Category
      </button>
    </form>
  </div>
  
  <p style="margin-top: 20px;"><a href="/categories">← Back to All Categories</a></p>
</article>

<%- include("partials/footer") %>