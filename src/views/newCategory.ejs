<%- include("partials/header") %>

<h2>Add New Category</h2>

<!-- Form action points to /categories where the POST route is registered -->
<form action="/categories" method="POST">
  <div>
    <label for="name">Category Name:</label>
    <input 
      type="text" 
      id="name" 
      name="name" 
      placeholder="Enter category name" 
      required
    >
  </div>

  <div>
    <label for="description">Description:</label>
    <textarea 
      id="description" 
      name="description" 
      placeholder="Enter description" 
      required
    ></textarea>
  </div>

  <div style="display: flex; gap: 1rem; align-items: center; margin-top: 0.5rem;">
    <button type="submit">Save Category</button>
    <a href="/categories" class="btn-sm" style="background-color: var(--text-muted); color: white !important; text-decoration: none; padding: 0.75rem 1.25rem; border-radius: var(--radius-sm); font-weight: 600;">Cancel</a>
  </div>
</form>

<%- include("partials/footer") %>