<%- include("partials/header") %>

<h2>Add New Organization</h2>

<form action="/organizations" method="POST" class="form-container">
  <div class="form-group" style="margin-bottom: 12px;">
    <label for="name">Organization Name:</label>
    <input type="text" id="name" name="name" required style="width: 100%; padding: 8px;">
  </div>

  <div class="form-group" style="margin-bottom: 12px;">
    <label for="description">Description:</label>
    <textarea id="description" name="description" rows="4" required style="width: 100%; padding: 8px;"></textarea>
  </div>

  <div class="form-group" style="margin-bottom: 12px;">
    <label for="location">Location:</label>
    <input type="text" id="location" name="location" style="width: 100%; padding: 8px;">
  </div>

  <button type="submit" class="btn btn-primary">Create Organization</button>
  <a href="/organizations" class="btn btn-secondary">Cancel</a>
</form>

<%- include("partials/footer") %>