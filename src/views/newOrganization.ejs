<%- include("partials/header") %>

<h2>Add New Organization</h2>

<form action="/organizations" method="POST" class="form-container">
  <div class="form-group" style="margin-bottom: 15px;">
    <label for="name" style="display: block; font-weight: bold; margin-bottom: 5px;">Organization Name:</label>
    <input type="text" id="name" name="name" required class="form-control" style="width: 100%; padding: 8px;">
  </div>

  <div class="form-group" style="margin-bottom: 15px;">
    <label for="email" style="display: block; font-weight: bold; margin-bottom: 5px;">Email Address:</label>
    <input type="email" id="email" name="email" required class="form-control" style="width: 100%; padding: 8px;">
  </div>

  <div class="form-group" style="margin-bottom: 15px;">
    <label for="image_url" style="display: block; font-weight: bold; margin-bottom: 5px;">Image URL:</label>
    <input type="text" id="image_url" name="image_url" class="form-control" style="width: 100%; padding: 8px;">
  </div>

  <button type="submit" class="btn btn-primary">Create Organization</button>
  <a href="/organizations" class="btn btn-secondary">Cancel</a>
</form>

<%- include("partials/footer") %>