<%- include("partials/header") %>

<div style="text-align: center; display: flex; flex-direction: column; align-items: center; padding: 1rem 1rem 1.5rem;">
  <h2 style="font-size: 1.85rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 0.5rem; color: var(--primary);">Welcome to the Service Learning Directory</h2>
  <p style="max-width: 500px; color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; line-height: 1.5;"><%= typeof message !== "undefined" ? message : "Explore service projects, partner organizations, and cause categories." %></p>

  <!-- Main Banner Image -->
  <img src="/images/home.jpg" alt="Service Learning Community" class="main-img" style="margin-left: auto; margin-right: auto; max-width: 440px; border-radius: var(--radius-md); box-shadow: var(--shadow-md);" />

  <div style="margin-top: 1.5rem; display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center;">
    <a href="/projects" class="tag" style="font-size: 0.9rem; padding: 9px 18px; border-radius: var(--radius-pill);">View Projects</a>
    <a href="/organizations" class="tag" style="font-size: 0.9rem; padding: 9px 18px; border-radius: var(--radius-pill);">View Organizations</a>
    <a href="/categories" class="tag" style="font-size: 0.9rem; padding: 9px 18px; border-radius: var(--radius-pill);">View Categories</a>
  </div>
</div>

<%- include("partials/footer") %>