<%- include("partials/header") %>

<h2>Edit Project: <%= project.title %></h2>

<form action="/project/<%= project.project_id %>/edit" method="POST" class="form-container">
  <div class="form-group" style="margin-bottom: 12px;">
    <label for="title">Project Title:</label>
    <input type="text" id="title" name="title" value="<%= project.title %>" required style="width: 100%; padding: 8px;">
  </div>

  <div class="form-group" style="margin-bottom: 12px;">
    <label for="organization_id">Organization:</label>
    <select id="organization_id" name="organization_id" required style="width: 100%; padding: 8px;">
      <% organizations.forEach(org => { %>
        <option value="<%= org.organization_id %>" <%= org.organization_id === project.organization_id ? 'selected' : '' %>><%= org.name %></option>
      <% }) %>
    </select>
  </div>

  <div class="form-group" style="margin-bottom: 12px;">
    <label for="location">Location:</label>
    <input type="text" id="location" name="location" value="<%= project.location %>" style="width: 100%; padding: 8px;">
  </div>

  <div class="form-group" style="margin-bottom: 12px;">
    <label for="project_date">Date:</label>
    <input type="date" id="project_date" name="project_date" value="<%= project.project_date %>" style="width: 100%; padding: 8px;">
  </div>

  <div class="form-group" style="margin-bottom: 12px;">
    <label for="description">Description:</label>
    <textarea id="description" name="description" rows="4" required style="width: 100%; padding: 8px;"><%= project.description %></textarea>
  </div>

  <button type="submit" class="btn btn-primary">Update Project</button>
  <a href="/project/<%= project.project_id %>" class="btn btn-secondary">Cancel</a>
</form>

<%- include("partials/footer") %>