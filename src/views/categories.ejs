<%- include("partials/header") %>

<main class="container" style="max-width: 900px; margin: 40px auto; padding: 0 15px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h2 style="margin: 0; font-size: 1.85rem; font-weight: 800; letter-spacing: -0.03em; color: var(--primary, #111827);">Categories</h2>
    <a href="/categories/new" class="btn">+ Add New Category</a>
  </div>

  <% if (typeof message !== "undefined" && message) { %>
    <div class="alert alert-success"><%= message %></div>
  <% } %>

  <% if (categories && categories.length > 0) { %>
    <div style="display: flex; flex-direction: column; gap: 1.25rem;">
      <% categories.forEach(category => { %>
        <div class="project-card" style="border: 1px solid var(--border-color, #e2e8f0); padding: 24px; border-radius: 12px; background: #ffffff; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);">
          
          <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px; flex-wrap: wrap; gap: 1rem;">
            <h3 style="margin: 0; font-size: 1.4rem; color: #0f172a;"><%= category.name %></h3>
            
            <div class="card-actions" style="display: flex; gap: 0.75rem; align-items: center;">
              <a href="/categories/<%= category.category_id %>/edit" class="action-btn edit-btn">Edit</a>
              
              <form action="/categories/<%= category.category_id %>/delete" method="POST" class="inline-form" style="margin: 0; padding: 0;">
                <button type="submit" class="action-btn delete-btn" onclick="return confirm('Are you sure you want to delete this category?');">Delete</button>
              </form>
            </div>
          </div>

          <div style="border-top: 1px solid #f1f5f9; padding-top: 15px;">
            <strong style="display: block; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; margin-bottom: 10px;">Associated Projects</strong>
            
            <% if (category.projects && category.projects.length > 0) { %>
              <div style="display: flex; flex-direction: column; gap: 8px;">
                <% category.projects.forEach(project => { %>
                  <div style="background: #f8fafc; border: 1px solid #e2e8f0; padding: 10px 14px; border-radius: 6px; color: #334155; font-weight: 500;">
                    <%= project.title %>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p style="margin: 0; color: #94a3b8; font-style: italic; font-size: 0.95rem;">No projects linked to this category.</p>
            <% } %>
          </div>

        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div style="text-align: center; padding: 40px; background: #f8fafc; border-radius: 12px; border: 1px dashed #cbd5e1;">
      <p style="color: #64748b; margin: 0 0 15px 0;">No categories found.</p>
      <a href="/categories/new" class="btn" style="text-decoration: none; padding: 8px 16px; background: #2563eb; color: white; border-radius: 6px; font-weight: 600;">Create your first category</a>
    </div>
  <% } %>
</main>

<style>
  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 90px;
    height: 34px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: normal;
    border-radius: var(--radius-sm, 6px);
    box-sizing: border-box;
    transition: none !important;
    transform: none !important;
    box-shadow: none !important;
  }
  .edit-btn {
    background-color: #ffffff !important;
    color: var(--accent, #2563eb) !important;
    border: 1px solid var(--border-color, #cbd5e1) !important;
    text-decoration: none !important;
  }
  .edit-btn:hover, .edit-btn:active {
    background-color: #ffffff !important;
    color: var(--accent, #2563eb) !important;
    transform: none !important;
    box-shadow: none !important;
  }
  .delete-btn {
    background-color: #ffffff !important;
    color: var(--danger, #dc2626) !important;
    border: 1px solid var(--danger, #dc2626) !important;
    cursor: pointer;
  }
  .delete-btn:hover, .delete-btn:active {
    background-color: #ffffff !important;
    color: var(--danger, #dc2626) !important;
    transform: none !important;
    box-shadow: none !important;
  }
</style>

<%- include("partials/footer") %>