<%- include("partials/header") %>

<div class="org-details" style="margin-top: 20px;">
  <h2><%= organization.name %></h2>
  
  <div style="display: flex; gap: 30px; margin-bottom: 30px; align-items: center;">
    <% if (organization.image_url) { %>
      <img src="<%= organization.image_url %>" alt="<%= organization.name %>" style="width: 200px; height: auto; border-radius: 8px;">
    <% } %>
    <div>
      <p><strong>Contact Email:</strong> <a href="mailto:<%= organization.email %>"><%= organization.email %></a></p>
    </div>
  </div>

  <hr style="border: 0; border-top: 1px solid #ccc; margin: 30px 0;">

  <h3>Active Service Projects</h3>
  <% if (projects && projects.length > 0) { %>
    <div class="projects-list">
      <% projects.forEach(project => { %>
        <div class="project-card" style="padding: 15px; border: 1px solid #ddd; border-radius: 6px; margin-bottom: 15px;">
          <h4><a href="/project/<%= project.project_id %>" style="color: #003366; text-decoration: none;"><%= project.title %></a></h4>
          <p style="margin: 5px 0;"><strong>Date:</strong> <%= project.project_date %> | <strong>Location:</strong> <%= project.location %></p>
          <p style="color: #555; margin: 5px 0 0 0;"><%= project.description %></p>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p style="font-style: italic; color: #666;">No service projects listed for this organization at this time.</p>
  <% } %>
</div>

<%- include("partials/footer") %>