<%- include("partials/header") %>

<h2><%= title %></h2>

<p>Here are a few of our partner organizations:</p>

<div class="org-list">
  <% if (organizations && organizations.length > 0) { %>
    <% organizations.forEach(org => { %>
      <div class="org-card" style="display: flex; gap: 15px; margin-bottom: 20px; border-bottom: 1px solid #ccc; padding-bottom: 15px;">
        
        <a href="/organization/<%= org.organization_id %>" class="org-image-link">
          <img src="<%= org.image_url || '/images/default-org.jpg' %>" alt="<%= org.name %>" style="width: 120px; height: auto; border-radius: 4px;">
        </a>
        
        <div>
          <h3>
            <a href="/organization/<%= org.organization_id %>" class="org-title-link">
              <%= org.name %>
            </a>
          </h3>
          <p><strong>Email:</strong> <%= org.email %></p>
        </div>

      </div>
    <% }) %>
  <% } else { %>
    <p>No partner organizations found in the database.</p>
  <% } %>
</div>

<%- include("partials/footer") %>