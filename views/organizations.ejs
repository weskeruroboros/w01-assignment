<%- include("partials/header") %>

<h2><%= title %></h2>

<p>Here are a few of our partner organizations:</p>

<div class="org-list">
  <% if (organizations && organizations.length > 0) { %>
    <% organizations.forEach(org => { %>
      <div class="org-card">
        <img src="<%= org.image_url || '/images/default-org.jpg' %>" alt="<%= org.name %>">
        <div>
          <h3><%= org.name %></h3>
          <p><%= org.email %></p>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p>No partner organizations found in the database.</p>
  <% } %>
</div>

<%- include("partials/footer") %>