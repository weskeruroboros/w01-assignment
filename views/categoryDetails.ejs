<%- include("partials/header") %>

<div class="category-details" style="margin-top: 20px;">
  <h2>Category: <%= category.name %></h2>
  <p style="font-size: 1.1rem; color: #555; margin-bottom: 30px;"><%= category.description || 'No description available for this category.' %></p>

  <h3>Service Projects under this Category</h3>
  <% if (projects && projects.length > 0) { %>
    <ul class="project-links-list" style="list-style-type: square; padding-left: 20px;">
      <% projects.forEach(project => { %>
        <li style="margin-bottom: 15px;">
          <a href="/project/<%= project.project_id %>" style="font-weight: bold; color: #003366; text-decoration: none; font-size: 1.1rem;">
            <%= project.title %>
          </a> 
          <span style="color: #777; font-size: 0.9rem;">— (<%= project.location %>)</span>
          <p style="margin: 4px 0 0 0; color: #444;"><%= project.description %></p>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p style="font-style: italic; color: #666;">No projects found matching this category right now.</p>
  <% } %>
</div>

<%- include("partials/footer") %>