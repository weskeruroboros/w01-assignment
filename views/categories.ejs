<%- include("partials/header") %>

<h2><%= title %></h2>

<ul class="categories-list">
  <% if (categories && categories.length > 0) { %>
    <% categories.forEach(category => { %>
      <li style="margin-bottom: 8px;">
        <a href="/category/<%= category.category_id %>" style="font-weight: 500; text-decoration: none; color: #003366;">
          <%= category.name %>
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li>No categories found in the database.</li>
  <% } %>
</ul>

<%- include("partials/footer") %>